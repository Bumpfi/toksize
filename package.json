{
	"name": "toksize",
	"version": "0.2.0",
	"description": "Know what's eating your context window. Token counter for your codebase.",
	"type": "module",
	"bin": {
		"toksize": "dist/cli.js"
	},
	"files": ["dist"],
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"dev": "tsup --watch",
		"build": "tsup",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "bun run build"
	},
	"keywords": [
		"tokens",
		"llm",
		"cli",
		"context-window",
		"tiktoken",
		"gpt",
		"claude",
		"ai",
		"developer-tools"
	],
	"license": "MIT",
	"dependencies": {
		"chalk": "^5.3.0",
		"cleye": "^1.3.2",
		"ignore": "^5.3.2",
		"js-tiktoken": "^1.0.15"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/node": "^22.9.0",
		"tsup": "^8.3.5",
		"typescript": "^5.6.3",
		"vitest": "^2.1.5"
	}
}
